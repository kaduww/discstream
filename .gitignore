# Dependencies and package-manager state
node_modules/
.pnpm-store/

# Build output
dist/
apps/*/dist/
packages/*/dist/
.turbo/
*.tsbuildinfo

# Local environment
.env
.env.*
!.env.example
discstream.env

# Runtime data generated by DiscStream
apps/*/runtime/
runtime/cache/*
runtime/config/*
runtime/covers/*
runtime/data/*
runtime/logs/*
runtime/streams/*
!runtime/cache/.gitkeep
!runtime/config/.gitkeep
!runtime/covers/.gitkeep
!runtime/data/.gitkeep
!runtime/logs/.gitkeep
!runtime/streams/.gitkeep

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test and browser artifacts
coverage/
test-results/
playwright-report/
blob-report/

# OS/editor files
.DS_Store
.idea/
.vscode/
