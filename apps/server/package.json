{
  "name": "@discstream/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/main.ts",
    "test": "vitest run --passWithNoTests",
    "test:smoke": "vitest run src/app.smoke.test.ts --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@discstream/contracts": "workspace:*",
    "@discstream/local-media": "workspace:*",
    "@discstream/platform": "workspace:*",
    "@fastify/static": "^8.0.3",
    "fastify": "^5.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
