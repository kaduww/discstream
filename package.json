{
  "name": "discstream",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "doctor": "./scripts/doctor.sh",
    "test": "pnpm -r test",
    "test:browser-smoke": "node scripts/browser-smoke.mjs",
    "test:smoke": "pnpm --filter @discstream/web build && pnpm --filter @discstream/server test:smoke",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "playwright": "^1.61.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
